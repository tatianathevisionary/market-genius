# BTC Genius — copy to .env, fill in, then: chmod 600 .env
# Real environment variables override these (.env values are setdefault).

# Webhook listener: shared secret for POST /hook/<secret>.
# Auto-generated on first run if absent.
WEBHOOK_SECRET=

# X / Twitter API v2 (https://developer.x.com) — bearer token is the only
# one the code uses; accounts is a comma-separated list of handles to poll.
X_BEARER_TOKEN=
X_API_KEY=
X_API_SECRET=
X_ACCOUNTS=BitcoinMagazine

# Reddit OAuth "script" app (https://www.reddit.com/prefs/apps).
# Optional — reddit_tracker.py falls back to public endpoints without it.
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
